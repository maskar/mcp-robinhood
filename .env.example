# Vault (credentials fetched from Vault override env vars below)
VAULT_ADDR=http://your-vault-host:8200
VAULT_TOKEN=hvs.your-vault-token

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_ALLOWED_EMAIL=you@example.com
PUBLIC_HOSTNAME=your-host.ts.net

# Fallback: direct credentials (used when Vault is unavailable)
# ROBINHOOD_USERNAME=you@example.com
# ROBINHOOD_PASSWORD=your-password
# ROBINHOOD_MFA_SECRET=AAAA BBBB CCCC DDDD
# ROBINHOOD_MFA_CODE=123456
